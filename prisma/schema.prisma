// ============================================================
// Prisma schema — SecuritasEtSalus
// ============================================================
// Docs: https://pris.ly/d/prisma-schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ------------------------------------------------------------
// Enums
// ------------------------------------------------------------

enum Role {
  SUPER_ADMIN
  INSTRUCTOR
  STUDENT
  // REGION_ADMIN se introduce cuando SES escale fuera de Chile.
  // Por ahora SUPER_ADMIN gestiona todo.
}

enum CourseStatus {
  DRAFT       // No visible en el catálogo público
  PUBLISHED   // Visible y abierto a inscripciones
  CLOSED      // Curso ya impartido y cerrado por el instructor
  CANCELLED   // Cancelado por SES (con/sin reembolsos)
}

enum EnrollmentStatus {
  PENDING_PAYMENT          // Creada pero el pago aún no se confirmó
  PENDING_SENCE_APPROVAL   // Solicitó franquicia SENCE — admin debe aprobar antes de pagar
  CONFIRMED                // Pagada (o aprobada SENCE) — el alumno ya está inscrito
  CANCELLED                // Cancelada por el alumno o por SES (libera cupo)
  COMPLETED                // El curso terminó y el alumno aprobó (genera diploma)
  FAILED                   // El curso terminó y el alumno no cumple requisitos
}

enum DiplomaStatus {
  ACTIVE
  REVOKED
  // SES no caducan: el diploma acredita un hecho histórico (formación recibida).
}

enum PaymentStatus {
  PENDING
  COMPLETED
  REFUNDED_FULL
  REFUNDED_PARTIAL
  FAILED
}

// ------------------------------------------------------------
// Usuarios y autenticación
// ------------------------------------------------------------

model User {
  id              String    @id @default(cuid())
  name            String
  email           String    @unique
  passwordHash    String?   // Null si solo usa Magic Link
  role            Role      @default(STUDENT)
  region          String?   // ISO 3166-1 alpha-2 del país (CL, AR, ...)
  subdivision     String?   // ISO 3166-2 (CL-RM, ...)
  phone           String?
  rut             String?   // RUT chileno cuando se usa franquicia SENCE
  avatarKey       String?   // Key en R2 (bucket ses-avatars) si subió foto
  emailVerifiedAt DateTime?
  // Suspensión de cuenta (acción admin). Si está rellena, el usuario
  // no puede iniciar sesión y la próxima validación de su sesión la
  // invalida. La fila no se borra para preservar diplomas históricos.
  suspendedAt     DateTime?
  suspendedReason String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relaciones
  enrollments              Enrollment[]
  diplomas                 Diploma[]
  payments                 Payment[]
  passwordResetTokens      PasswordResetToken[]
  emailVerificationTokens  EmailVerificationToken[]
  coursesAsInstructor      Course[]                  @relation("CourseInstructor")
  attendancesMarked        Attendance[]              @relation("AttendanceMarker")
  evaluationsGiven         Evaluation[]              @relation("EvaluationEvaluator")
  // NextAuth (Magic Link via @auth/prisma-adapter)
  accounts                 Account[]
  sessions                 Session[]

  @@index([email])
  @@index([role])
}

// ------------------------------------------------------------
// NextAuth (@auth/prisma-adapter)
// ------------------------------------------------------------
// Modelos requeridos por el adaptador para gestionar Magic Link y futuras
// integraciones OAuth. La sesión real va por JWT, pero el adapter usa
// VerificationToken para validar el token enviado por correo.

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String   // email del usuario
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([tokenHash])
}

model EmailVerificationToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([tokenHash])
}

// ------------------------------------------------------------
// Cursos y sesiones
// ------------------------------------------------------------

model Course {
  id                                  String       @id @default(cuid())
  title                               String
  slug                                String       @unique
  shortDescription                    String       // Para cards del catálogo
  fullSyllabus                        String       // Markdown — temario completo
  durationHours                       Int          // Total de horas lectivas
  price                               Int          // En la unidad mínima (CLP es zero-decimal)
  currency                            String       @default("CLP")  // ISO 4217
  capacity                            Int
  region                              String       @default("CL")
  subdivision                         String?
  venueName                           String?
  venueAddress                        String?
  status                              CourseStatus @default(DRAFT)

  // Flags de comportamiento
  hasEvaluation                       Boolean      @default(true)
  senceEligible                       Boolean      @default(false)  // Apto franquicia SENCE

  // Configuración de la evaluación final (Fase 5b).
  // Escala chilena tradicional 1-7, con 4.0 como nota mínima de aprobación.
  // El instructor evalúa al alumno en hasta 4 dimensiones; las activas
  // por defecto son las cuatro, pero `evaluatesAttitude` se puede apagar
  // por curso si el formato no requiere medir actitud (cursos cortos,
  // talleres puntuales, etc.).
  evaluationPassingGrade              Float        @default(4.0)
  evaluatesAttitude                   Boolean      @default(true)

  // Mapeo a Clavero. Si claveroSkillCode != null, el diploma de este curso
  // sirve como input para certificación profesional Clavero. Códigos
  // canónicos del catálogo SENCE: LE, LP, L3, AB, AA, AA+, V1, V2, M1, M2.
  // Suffix opcional 'e+' para L3 cuando la sede tiene máquina avanzada.
  claveroSkillCode                    String?
  claveroSkillSuffix                  String?

  // Prerrequisitos: códigos de skills SES que el alumno debe acreditar
  // (vía diploma previo) para poder inscribirse a este curso. Vacío = sin
  // prerrequisitos. Validación en Fase 4 (checkout).
  prerequisiteSkillCodes              String[]

  // Kit incluido (markdown) — describe el hardware/herramientas que se
  // entregan al alumno además de la formación. Parte de la propuesta de
  // valor según el catálogo SENCE.
  includedKit                         String?

  instructorId                        String
  instructor                          User         @relation("CourseInstructor", fields: [instructorId], references: [id])

  publishedAt                         DateTime?
  closedAt                            DateTime?
  createdAt                           DateTime     @default(now())
  updatedAt                           DateTime     @updatedAt

  sessions                            CourseSession[]
  enrollments                         Enrollment[]
  diplomas                            Diploma[]

  @@index([status])
  @@index([slug])
  @@index([region])
  @@index([instructorId])
}

model CourseSession {
  id            String       @id @default(cuid())
  courseId      String
  course        Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  sessionNumber Int          // 1, 2, 3...
  startsAt      DateTime
  endsAt        DateTime
  location      String?      // Si es distinta de la sede principal del curso

  // El cron de course-reminders sella esta fecha cuando manda el aviso
  // de "tu curso empieza en 48h" para evitar enviarlo dos veces. Solo
  // aplica a la primera sesión de cada curso.
  reminderSentAt DateTime?

  attendances   Attendance[]

  @@unique([courseId, sessionNumber])
  @@index([courseId])
  @@index([startsAt])
}

// ------------------------------------------------------------
// Inscripciones, asistencia, pagos
// ------------------------------------------------------------

model Enrollment {
  id               String           @id @default(cuid())
  userId           String
  user             User             @relation(fields: [userId], references: [id])
  courseId         String
  course           Course           @relation(fields: [courseId], references: [id])
  status           EnrollmentStatus @default(PENDING_PAYMENT)
  enrolledAt       DateTime         @default(now())
  paidAt           DateTime?
  cancelledAt      DateTime?        // Si status=CANCELLED, cuándo se canceló
  cancelReason     String?          // Motivo de la cancelación (alumno o admin)
  finalGrade       Float?           // Nota final si el curso tiene evaluación
  failedReason     String?          // 'attendance' | 'evaluation' | 'both' (si status=FAILED)

  // SENCE
  senceUsed        Boolean          @default(false)
  employerRut      String?          // RUT del empleador si se aplicó franquicia
  employerName     String?
  employerHrEmail  String?
  senceRejectionReason String?      // Si admin rechazó la solicitud SENCE

  attendances      Attendance[]
  payments         Payment[]
  diploma          Diploma?
  evaluation       Evaluation?

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([status])
}

model Attendance {
  id           String        @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment    @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  sessionId    String
  session      CourseSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  attended     Boolean       @default(false)
  markedById   String        // userId del instructor que marcó
  markedBy     User          @relation("AttendanceMarker", fields: [markedById], references: [id])
  markedAt     DateTime      @default(now())

  @@unique([enrollmentId, sessionId])
  @@index([sessionId])
}

// ------------------------------------------------------------
// Evaluación final del alumno (Fase 5b)
// ------------------------------------------------------------
// Se crea al cierre del curso: el instructor evalúa al alumno en hasta
// 4 dimensiones con nota chilena 1-7. La nota final es el promedio de las
// dimensiones activas (la actitud se puede desactivar por curso vía
// Course.evaluatesAttitude). El campo `passed` se calcula al guardar
// teniendo en cuenta el umbral del curso y la asistencia mínima (75%).
//
// 1:1 con Enrollment — un alumno solo se evalúa una vez por curso.
// El instructor puede editar la evaluación las veces que quiera hasta
// que el curso pase a CLOSED.

model Evaluation {
  id           String     @id @default(cuid())
  enrollmentId String     @unique
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  // Notas por dimensión, escala chilena 1-7. Nullable porque el form se
  // puede guardar parcial (el instructor puede ir rellenando) y porque
  // la dimensión de actitud puede estar desactivada en el curso.
  technicalScore     Float?  // Técnica: ¿ejecuta correctamente las tareas del curso?
  knowledgeScore     Float?  // Conocimientos: ¿entiende el porqué, no solo el cómo?
  attitudeScore      Float?  // Actitud: puntualidad, ética, profesionalidad
  participationScore Float?  // Participación: trabajo en equipo, preguntas

  // Calculados al guardar.
  finalGrade Float?    // Promedio de dimensiones activas con nota.
  passed     Boolean?  // true si finalGrade >= Course.evaluationPassingGrade Y asistencia >= 75%.

  notes String?  // Comentarios libres del instructor.

  evaluatedById String
  evaluatedBy   User     @relation("EvaluationEvaluator", fields: [evaluatedById], references: [id])
  evaluatedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([evaluatedById])
}

model Payment {
  id                String        @id @default(cuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id])
  enrollmentId      String
  enrollment        Enrollment    @relation(fields: [enrollmentId], references: [id])
  stripePaymentId   String        @unique  // cs_xxx — idempotencia
  amount            Int                    // En la unidad mínima
  currency          String        @default("CLP")
  status            PaymentStatus @default(PENDING)
  paidAt            DateTime?
  refundedAt        DateTime?
  refundedAmount    Int?                   // En caso de reembolso parcial
  receiptKey        String?                // Key en R2 del recibo PDF
  createdAt         DateTime      @default(now())

  @@index([userId])
  @@index([enrollmentId])
  @@index([status])
}

// ------------------------------------------------------------
// Diplomas
// ------------------------------------------------------------

model Diploma {
  id           String        @id @default(cuid())
  code         String        @unique  // Código corto público (verificable por QR)
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  courseId     String
  course       Course        @relation(fields: [courseId], references: [id])
  enrollmentId String        @unique
  enrollment   Enrollment    @relation(fields: [enrollmentId], references: [id])
  status       DiplomaStatus @default(ACTIVE)
  issuedAt     DateTime      @default(now())
  pdfKey       String?       // Key en R2 del PDF generado
  revokedAt    DateTime?
  revocationReason String?

  @@index([userId])
  @@index([courseId])
  @@index([code])
  @@index([status])
}
