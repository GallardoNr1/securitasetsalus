# ============================================================
# SecuritasEtSalus — Variables de entorno
# ============================================================
# Copiar este archivo a .env.local y rellenar los valores reales.
# En Vercel, configurar todas estas variables en Settings → Env Vars.
#
# Estado por fase:
#  - Fase 0: ninguna obligatoria — la app arranca con .env.local vacío.
#  - Fase 2 (auth): obligatorias DATABASE_URL, DIRECT_URL, NEXTAUTH_SECRET,
#                   RESEND_API_KEY, EMAIL_FROM (Magic Link necesita Resend).
#  - Fase 4 (pagos): obligatorias STRIPE_*.
#  - Fase 5 (storage): obligatorias R2_*.
# ============================================================

# --- App ---
NEXT_PUBLIC_APP_URL=https://securitasetsalus.cl

# --- Base de datos (Supabase, proyecto SES, región us-east-1) ---
# Pooled connection (puerto 6543) para runtime serverless.
DATABASE_URL=
# Direct connection (puerto 5432) para migraciones y session pool.
DIRECT_URL=

# --- NextAuth (Auth.js v5) ---
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# OJO: Auth.js v5 lee AUTH_SECRET, no NEXTAUTH_SECRET. En Vercel debe llamarse así.
AUTH_SECRET=
# En Vercel dejar vacío — se calcula automáticamente. Solo rellenar en local si hace falta.
AUTH_URL=http://localhost:3000

# --- Stripe (Fase 4) ---
# Cuenta propia de SES (separada de la de Clavero). Test mode hasta validación SpA.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Cloudflare R2 ---
# UN ÚNICO bucket con prefijos (avatars/, diplomas/, materials/, receipts/)
# en lugar de cuatro buckets separados — más simple de operar y mismo modelo
# que usa Clavero. Las 4 vars BUCKET_NAME_* apuntan deliberadamente al mismo
# bucket físico; el prefijo en la key separa los artefactos.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME_AVATARS=securitas-et-salus
R2_BUCKET_NAME_DIPLOMAS=securitas-et-salus
R2_BUCKET_NAME_MATERIALS=securitas-et-salus
R2_BUCKET_NAME_RECEIPTS=securitas-et-salus
R2_PUBLIC_URL=

# --- Email (Resend, Fase 7) ---
RESEND_API_KEY=
# Acepta "noreply@dominio.com" o '"SecuritasEtSalus" <noreply@dominio.com>'.
EMAIL_FROM=SecuritasEtSalus <noreply@securitasetsalus.cl>
# Protege /api/cron/*. Generar con el mismo comando de NEXTAUTH_SECRET.
CRON_SECRET=

# --- Sentry ---
NEXT_PUBLIC_SENTRY_DSN=
# Para subir source maps en build de Vercel.
SENTRY_AUTH_TOKEN=

# --- Seed inicial (solo para `npm run prisma:seed`) ---
SEED_SUPER_ADMIN_EMAIL=
SEED_SUPER_ADMIN_PASSWORD=
SEED_SUPER_ADMIN_NAME=Super Administrador
SEED_SUPER_ADMIN_REGION=CL
